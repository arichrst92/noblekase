{
  "name": "noblekase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "migrate:fresh": "payload migrate:fresh",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seed.ts",
    "seed:content": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seedContent.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/email-resend": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/translations": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@types/redis": "^4.0.10",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "graphql": "^16.9.0",
    "groq-sdk": "^0.9.0",
    "gsap": "^3.12.5",
    "lucide-react": "^0.460.0",
    "next": "15.0.3",
    "next-intl": "^3.25.0",
    "openai": "^4.73.0",
    "payload": "^3.0.0",
    "react": "19.0.0-rc-65a56d0e-20241020",
    "react-dom": "19.0.0-rc-65a56d0e-20241020",
    "redis": "^4.7.0",
    "resend": "^4.0.1",
    "sharp": "0.32.6",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.0.3",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": "^20.9.0 || ^22.0.0",
    "pnpm": "^9 || ^10"
  },
  "packageManager": "pnpm@9.12.3"
}
