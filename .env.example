# ============================================
# Noblekase — Environment Variables
# Dibuat oleh: PT Solusi Inovasi Bangsa (https://ide.asia)
# ============================================
# Copy file ini menjadi .env.local untuk development,
# atau .env untuk production. JANGAN commit ke git.
#
# CATATAN: Sebagian besar API key (GROQ, RESEND, Google Indexing, GA4) kini
# bisa diisi lewat CMS di Admin -> System -> "API Keys & Integrasi" (super-admin).
# Nilai di CMS MENGGANTIKAN nilai di file ini, jadi client tidak perlu edit .env.
# Yang WAJIB tetap di sini: PAYLOAD_SECRET, DATABASE_URI, REDIS_URL, SERVER_URL.

# ============================================
# CORE
# ============================================
# WAJIB diisi domain asli di production. Nilai ini dipakai untuk canonical,
# hreflang, sitemap, dan URL yang diajukan ke Google Indexing — kalau masih
# localhost, seluruh metadata SEO ikut salah.
# Development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://noblekase.co.id

# Bahasa default situs. Harus sama dengan `defaultLocale` di src/lib/i18n.ts
# dan `localization.defaultLocale` di src/payload.config.ts.
NEXT_PUBLIC_DEFAULT_LOCALE=id

# Payload secret untuk JWT signing (generate via: openssl rand -base64 32)
PAYLOAD_SECRET=replace-me-with-random-string

# Server URL untuk Payload (sama dengan NEXT_PUBLIC_SITE_URL biasanya)
SERVER_URL=http://localhost:3000
# Production: SERVER_URL=https://noblekase.co.id

# ============================================
# DATABASE
# ============================================
# Development (Postgres lokal di mesin Anda):
DATABASE_URI=postgres://noblekase:noblekase@localhost:5432/noblekase
#
# PRODUCTION (Docker Compose): JANGAN isi DATABASE_URI di sini.
# docker-compose.yml menyusunnya otomatis dari tiga variabel di bawah dan
# menunjuk ke service `postgres`, bukan localhost. Mengisi DATABASE_URI di
# .env justru menimpanya dan aplikasi akan mencari database di dalam
# containernya sendiri.
POSTGRES_USER=noblekase
POSTGRES_PASSWORD=ganti-dengan-password-kuat
POSTGRES_DB=noblekase

# ============================================
# REDIS (cache, rate limiting, AI response cache)
# ============================================
# Development. Di Docker Compose nilainya di-override jadi redis://redis:6379.
REDIS_URL=redis://localhost:6379

# ============================================
# AI — GROQ
# ============================================
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model selection per use case (override defaults if needed)
GROQ_MODEL_CHATBOT=llama-3.1-8b-instant
GROQ_MODEL_MARKET_INTEL=llama-3.3-70b-versatile
GROQ_MODEL_BLOG=llama-3.3-70b-versatile

# Cost cap per bulan (USD) — saat tercapai, AI features auto-disable
AI_BUDGET_CAP_USD=30

# ============================================
# EMAIL — RESEND
# ============================================
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@noblekase.co.id
EMAIL_REPLY_TO=halo@noblekase.co.id

# ============================================
# GOOGLE INTEGRATIONS
# ============================================
# Service account JSON path untuk Indexing API
GOOGLE_INDEXING_SERVICE_ACCOUNT_PATH=./secrets/google-indexing-key.json
GOOGLE_SEARCH_CONSOLE_PROPERTY=https://noblekase.co.id/

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# UPLOADS / STORAGE
# ============================================
# Directory mount untuk image uploads
UPLOAD_DIR=./uploads

# ============================================
# RATE LIMITING (per minute)
# ============================================
RATE_LIMIT_PUBLIC=120
RATE_LIMIT_SEARCH=60
RATE_LIMIT_AI_CHAT=20
RATE_LIMIT_AI_ADMIN=10

# ============================================
# AKUN ADMIN PERTAMA (dipakai `pnpm create:admin`)
# ============================================
# Hanya untuk membuat user pertama di server baru. Setelah akun jadi,
# KOSONGKAN kembali ADMIN_PASSWORD — jangan biarkan tersimpan di .env server.
ADMIN_EMAIL=admin@noblekase.co.id
ADMIN_NAME=Administrator
ADMIN_PASSWORD=

# ============================================
# FEATURE FLAGS (untuk progressive rollout)
# ============================================
FEATURE_AI_CHATBOT=true
FEATURE_AI_MARKET_INTEL=true
FEATURE_AI_BLOG_DRAFT=true
FEATURE_AI_AUTO_TRANSLATE=true
